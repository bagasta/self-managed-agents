# Copy to .env and fill in values
DATABASE_URL=postgresql+asyncpg://postgres:Binatanglaut123.@localhost:5432/managed_agents
DB_POOL_SIZE=16
DB_MAX_OVERFLOW=16
DB_POOL_TIMEOUT_SECONDS=10
DB_POOL_RECYCLE_SECONDS=1800
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=64
REDIS_POOL_TIMEOUT_SECONDS=5
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=3
REDIS_SOCKET_TIMEOUT_SECONDS=10
REDIS_HEALTH_CHECK_INTERVAL_SECONDS=30
OPENROUTER_API_KEY=sk-or-v1-...
MISTRAL_API_KEY=                    # Required for PDF OCR (mistral-ocr-latest)
TAVILY_API_KEY=                     # Required for Tavily web browsing tools
TAVILY_FORCE_IPV4=true              # Prefer IPv4 for Tavily; avoids IPv6/NAT64 TLS timeouts on some hosts
API_KEY=change-me-to-a-random-secret
LOG_LEVEL=INFO

# Sandbox
SANDBOX_BASE_DIR=/tmp/agent-sandboxes
# Host path that backs SANDBOX_BASE_DIR. Required when the app runs INSIDE a container
# and spawns sibling sandbox containers via the mounted Docker socket: bind sources are
# resolved by the host daemon, so the app path must map to its host equivalent.
# Leave empty for dev / app-on-host (no translation). In docker-compose we set both to
# /opt/agent-sandboxes (identical host:container path).
SANDBOX_HOST_BASE_DIR=
DOCKER_SANDBOX_IMAGE=python:3.12-slim
# Docker socket path — use unix:///run/docker.sock on modern Linux
DOCKER_HOST=unix:///run/docker.sock
# Re-enable sandbox/subagent/deploy/tool_creator (set false to kill-switch them)
SANDBOX_SUBAGENTS_ENABLED=true
# Per-container resource caps (tune per VPS size)
SANDBOX_MEM_LIMIT=1g
SANDBOX_NANO_CPUS=1000000000
# Max concurrent sandbox runs (others queue via semaphore)
MAX_CONCURRENT_SANDBOXES=6

# Agent limits
AGENT_MAX_STEPS=12
AGENT_TIMEOUT_SECONDS=300
# Different sessions run concurrently, but burst traffic queues above this limit.
MAX_CONCURRENT_AGENT_RUNS=24
WA_SERVICE_WEBHOOK_MAX_IN_FLIGHT=48
WA_DEV_AGENT_MAX_IN_FLIGHT=48

# Production Uvicorn stays single-worker until session locks are distributed.
API_LIMIT_CONCURRENCY=128
API_BACKLOG=2048
API_KEEP_ALIVE_SECONDS=5
API_GRACEFUL_SHUTDOWN_SECONDS=45
# Set false when deploy/docker-compose.prod.yml runs the dedicated scheduler service.
EMBEDDED_SCHEDULER_ENABLED=true

# WhatsApp microservice (wa-service)
WA_SERVICE_URL=http://localhost:8080
WA_DEV_SERVICE_URL=http://localhost:8081
WA_DEV_PUBLIC_PHONE=
WA_DEV_PUBLIC_NAME="Arthur AI Dev"
WORKSPACE_MCP_URL=http://localhost:8002/mcp
WORKSPACE_MCP_RUNTIME_URL=http://localhost:8002/mcp  # URL runtime untuk tool call MCP; bisa beda dengan URL auth/tunnel
WORKSPACE_MCP_PREFER_LOCAL=true                      # true = google_workspace tool call pakai runtime/local URL
WORKSPACE_MCP_TOKEN=                       # Bearer token untuk akses MCP server (fallback global)
GOOGLE_INTEGRATION_SERVICE_URL=http://localhost:8003  # Service OAuth Google Workspace (pakai tunnel URL di prod)
