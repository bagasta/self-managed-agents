# Copy to .env and fill in values
DATABASE_URL=postgresql+asyncpg://postgres:Binatanglaut123.@localhost:5432/managed_agents
OPENROUTER_API_KEY=sk-or-v1-...
MISTRAL_API_KEY=                    # Required for PDF OCR (mistral-ocr-latest)
TAVILY_API_KEY=                     # Required for Tavily web browsing tools
TAVILY_FORCE_IPV4=true              # Prefer IPv4 for Tavily; avoids IPv6/NAT64 TLS timeouts on some hosts
API_KEY=change-me-to-a-random-secret
LOG_LEVEL=INFO

# Sandbox
SANDBOX_BASE_DIR=/tmp/agent-sandboxes
DOCKER_SANDBOX_IMAGE=python:3.12-slim
# Docker socket path — use unix:///run/docker.sock on modern Linux
DOCKER_HOST=unix:///run/docker.sock

# Agent limits
AGENT_MAX_STEPS=12
AGENT_TIMEOUT_SECONDS=300

# WhatsApp microservice (wa-service)
WA_SERVICE_URL=http://localhost:8080
WORKSPACE_MCP_URL=http://localhost:8002/mcp
WORKSPACE_MCP_RUNTIME_URL=http://localhost:8002/mcp  # URL runtime untuk tool call MCP; bisa beda dengan URL auth/tunnel
WORKSPACE_MCP_PREFER_LOCAL=true                      # true = google_workspace tool call pakai runtime/local URL
WORKSPACE_MCP_TOKEN=                       # Bearer token untuk akses MCP server (fallback global)
GOOGLE_INTEGRATION_SERVICE_URL=http://localhost:8003  # Service OAuth Google Workspace (pakai tunnel URL di prod)
